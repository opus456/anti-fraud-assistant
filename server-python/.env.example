# 反诈智能体助手 - Python AI 决策引擎环境变量示例
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接
DATABASE_URL=postgresql+asyncpg://antifraud:antifraud123@localhost:5432/antifraud

# Redis 缓存连接
REDIS_URL=redis://localhost:6379/0

# ==================== 本地 Ollama 模型配置（推荐）====================
# 是否使用本地 Ollama 模型（True/False）
USE_LOCAL_LLM=True

# Ollama 服务地址（默认 http://localhost:11434）
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 模型名称（需要先通过 ollama pull 下载）
# 支持的模型: llama3.1, llama3.1:70b, qwen2.5, mistral 等
OLLAMA_MODEL=llama3.1

# Ollama 请求超时时间（秒），本地模型推理可能较慢
OLLAMA_TIMEOUT=120.0

# 是否每次检测都使用 LLM（提高准确率，但会增加响应时间）
ALWAYS_USE_LLM=True

# ==================== 远程 LLM API 配置（备用）====================
# 如果本地 Ollama 不可用，系统会自动回退到远程 API
# 远程 API 地址（OpenAI 兼容格式）
LLM_API_URL=https://api-ai.gitcode.com/v1/chat/completions

# 远程 API 密钥（留空则不使用远程 API）
LLM_API_KEY=

# 远程模型名称
LLM_MODEL=Qwen/Qwen3.5-35B-A3B

# ==================== 安全配置 ====================
# JWT 密钥（生产环境请务必修改！）
SECRET_KEY=anti-fraud-change-this-in-production

# ==================== 调试配置 ====================
# 调试模式（生产环境请设为 False）
DEBUG=True

# ==================== 使用说明 ====================
# 1. 安装 Ollama: https://ollama.com/download
# 2. 下载模型: ollama pull llama3.1
# 3. 启动 Ollama 服务: ollama serve
# 4. 复制此文件为 .env
# 5. 启动 Python 服务: python run.py
