# 反诈智能体助手 - 生产环境配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 数据库 ====================
POSTGRES_DB=antifraud
POSTGRES_USER=antifraud
POSTGRES_PASSWORD=your-secure-password-here

# ==================== 安全 ====================
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# ==================== 调试模式 ====================
DEBUG=false

# ==================== LLM 配置 ====================
# 如果服务器本地安装了 Ollama，设置为 true
USE_LOCAL_LLM=true

# Ollama 地址 (Docker 内访问宿主机使用 host.docker.internal)
# Linux 服务器可能需要改为: http://172.17.0.1:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama 模型名称
OLLAMA_MODEL=gemma4:e4b

# 远程 LLM API (当 USE_LOCAL_LLM=false 或 Ollama 不可用时使用)
LLM_API_URL=https://api-ai.gitcode.com/v1/chat/completions
LLM_API_KEY=your-api-key-here

# ==================== Embedding 服务 ====================
EMBEDDING_API_URL=https://api-ai.gitcode.com/v1
ACCESS_TOKEN=your-embedding-api-token-here
